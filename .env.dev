# ==========================================
# 迅捷后台管理系统 - 开发环境配置 (Development)
# ==========================================

PROJECT_NAME="迅捷后台管理系统 (Dev)"
API_V1_STR="/api/v1"

# 本地开发用固定密钥即可
SECRET_KEY="supersecretkeyreplaceinproduction"
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# 本地数据库连接 (使用 localhost:3306)
DATABASE_URL="mysql+aiomysql://root:666666@localhost:3306/xunjie_bigscreen"

# JWT configuration
ALGORITHM="HS256"

# 验证码配置 (0: 从不开启, 1: 始终开启, 2: 智能触发/阶梯触发)
CAPTCHA_POLICY=0
CAPTCHA_MAX_FAILURES=1
CAPTCHA_IP_LIMIT_PERIOD=10
CAPTCHA_IP_LIMIT_COUNT=5


# 跨域设置：包含本地开发常见端口
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000"

# 本地启动服务器参数
HOST="127.0.0.1"
PORT=8000
RELOAD=True
