PROJECT_NAME="迅捷后台管理系统"
API_V1_STR="/api/v1"
SECRET_KEY="supersecretkeyreplaceinproduction"
ACCESS_TOKEN_EXPIRE_MINUTES=10080
DATABASE_URL="mysql+aiomysql://root:password@localhost:3306/xunjie_bigscreen"

# JWT configuration
ALGORITHM="HS256"

# Captcha configuration (0: 从不开启, 1: 始终开启, 2: 智能触发/阶梯触发)
CAPTCHA_POLICY=0
CAPTCHA_MAX_FAILURES=1
CAPTCHA_IP_LIMIT_PERIOD=10
CAPTCHA_IP_LIMIT_COUNT=5


# CORS configurations (comma-separated list of origins)
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000"

# Server configuration
HOST="127.0.0.1"
PORT=8000
RELOAD=True

# ==========================================
# 资源存储管理配置 (Storage & Object Bucket)
# ==========================================
# 存储类型：local (本地存储) 或 oss (对象存储，如 MinIO, 阿里云 OSS, AWS S3 等)
STORAGE_TYPE="local"

# 对象存储配置 (当 STORAGE_TYPE="oss" 时生效)
# 存储桶服务 Endpoint 地址，本地开发测试推荐 MinIO 默认地址 http://127.0.0.1:9000
STORAGE_OSS_ENDPOINT="http://127.0.0.1:9000"

# 存储桶 Bucket 名称，如 "bigscreen"
STORAGE_OSS_BUCKET="bigscreen"

# 存储桶 Access Key ID
STORAGE_OSS_ACCESS_KEY="your-access-key"

# 存储桶 Secret Access Key
STORAGE_OSS_SECRET_KEY="your-secret-key"

# 存储桶所在 Region 区域，例如 "us-east-1"
STORAGE_OSS_REGION="us-east-1"

# 存储桶对外访问的自定义域名 (如配置了 CDN 或 Nginx 代理，非必填)，例如 "http://cdn.yourdomain.com"
STORAGE_OSS_DOMAIN=""

